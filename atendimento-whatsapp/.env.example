# =========================================================================
# Configuração da stack de atendimento - Ótica SANRE
#
# COMO USAR:
#   1. Copie este arquivo para ".env":   cp .env.example .env
#   2. Preencha os valores marcados com <GERAR>
#   3. NUNCA suba o .env pro git (já está no .gitignore)
#
# Para gerar segredos fortes, rode no terminal da VPS:
#   openssl rand -hex 32
# =========================================================================

# --- Banco de dados (Postgres) -------------------------------------------
POSTGRES_USER=sanre
POSTGRES_PASSWORD=<GERAR>          # ex: openssl rand -hex 16

# --- Evolution API (WhatsApp) --------------------------------------------
# Chave que protege a API. Você usa ela pra criar a instância e ligar o QR.
EVOLUTION_API_KEY=<GERAR>          # ex: openssl rand -hex 32

# --- n8n (cérebro) -------------------------------------------------------
N8N_ENCRYPTION_KEY=<GERAR>         # ex: openssl rand -hex 32
# Enquanto testa por IP, deixe assim. Quando tiver domínio, troque:
#   N8N_HOST=n8n.seudominio.com
#   N8N_PROTOCOL=https
#   N8N_WEBHOOK_URL=https://n8n.seudominio.com/
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/

# --- Gemini (IA) - usado dentro do n8n na Fase 3 -------------------------
# Pegue em https://aistudio.google.com/apikey  (a chave NÃO vai aqui;
# você cola ela direto no n8n como credencial. Deixado como lembrete.)
# GEMINI_API_KEY=...

# --- Chatwoot (inbox humano) - só na Fase 4 ------------------------------
CHATWOOT_SECRET_KEY_BASE=<GERAR>   # ex: openssl rand -hex 64
# Enquanto testa por IP: http://SEU_IP:3000 ; com domínio: https://chat.seudominio.com
CHATWOOT_FRONTEND_URL=http://localhost:3000
